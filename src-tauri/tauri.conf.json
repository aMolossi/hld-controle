{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HubControl",
  "version": "0.3.1",
  "identifier": "com.hubcontrol.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HubControl",
        "width": 1280,
        "height": 832,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMjczRjE3OUMwNDNGRTcKUldUblB3U2NGejhuMjVrQkpPdDk3NHpFQ3lveXd3eVhQNXpjMU5rSGtyUURyam5ZZnlnTUI0b1AK",
      "endpoints": [
        "https://github.com/aMolossi/hld-controle/releases/latest/download/latest.json"
      ]
    }
  }
}
